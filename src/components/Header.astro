---
const links = [
  { href: '/', label: 'Головна' },
  { href: '/poslugy', label: 'Послуги' },
  { href: '/tsiny', label: 'Ціни' },
  { href: '/blog', label: 'Блог' },
  { href: '/robota', label: 'Робота' },
  { href: '/kontakty', label: 'Контакти' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site"><div class="container nav">
  <a href="/" class="logo"><span class="mark"><svg viewBox="0 0 24 24"><path d="M12 3 3 10v11h6v-6h6v6h6V10z"/></svg></span> Буд<b>Сміла</b></a>
  <nav class="nav-links">
    {links.map((l) => (
      <a href={l.href} class={path === l.href.replace(/\/$/, '') || (l.href === '/' && path === '/') ? 'active' : ''}>{l.label}</a>
    ))}
  </nav>
  <a href="https://vgb.team/" target="_blank" rel="noopener" class="btn cta">Замовити прорахунок</a>
  <button class="burger" aria-label="Меню">☰</button>
</div></header>

<script>
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.closest('.burger')) {
      document.querySelector('.nav-links')?.classList.toggle('open');
    }
  });
</script>
