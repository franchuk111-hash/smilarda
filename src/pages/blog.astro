---
import Base from '../layouts/Base.astro';
const bc = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: 'https://smilarda.org.ua/' },
    { '@type': 'ListItem', position: 2, name: 'Блог', item: 'https://smilarda.org.ua/blog' },
  ],
};
const posts = [
  { href: '/blog/pokrivlya', ico: '🏠', cat: 'Покрівля', title: 'Як вибрати покрівлю для приватного будинку', text: 'Металочерепиця, профнастил чи бітумна черепиця — порівнюємо за ціною, довговічністю, вагою та монтажем.', min: '7 хв читання' },
  { href: '/blog/uteplennya', ico: '🧱', cat: 'Фасад', title: 'Утеплення фасаду: матеріали та ціни 2026', text: 'Мінеральна вата чи пінополістирол, яку товщину обрати та скільки коштує «мокрий фасад» у Смілі.', min: '6 хв читання' },
  { href: '/blog/remont', ico: '🛠️', cat: 'Ремонт', title: 'Ремонт квартири під ключ: етапи та бюджет', text: 'Покрокова послідовність робіт — від демонтажу до чистового оздоблення, щоб нічого не забути й не переплатити.', min: '8 хв читання' },
];
---
<Base
  title="Блог про будівництво та ремонт у Смілі — поради й гайди | БудСміла"
  description="Статті та гайди про будівництво і ремонт: як вибрати покрівлю, чим утеплити фасад, етапи ремонту квартири під ключ. Практичні поради для мешканців Сміли та Черкаської області."
  path="/blog"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(bc)} />

  <div class="container"><div class="crumbs"><a href="/">Головна</a> → Блог</div></div>

  <section class="block" style="padding-top:6px"><div class="container">
    <p class="kicker">Блог</p>
    <h2 class="title">Поради з будівництва та ремонту</h2>
    <p class="sub">Розбираємо матеріали, технології та ціни простою мовою — щоб ви ухвалювали зважені рішення щодо свого житла.</p>

    <div class="posts">
      {posts.map((p) => (
        <a class="post" href={p.href}><div class="cover">{p.ico}</div><div class="body"><span class="cat">{p.cat}</span><h3>{p.title}</h3><p>{p.text}</p><span class="meta">{p.min}</span></div></a>
      ))}
    </div>
  </div></section>

  <section class="block" style="padding-top:0"><div class="container">
    <div class="partner">
      <div>
        <span class="badge">⭐ Рекомендований підрядник</span>
        <h2>Від теорії — до готового об'єкта</h2>
        <p>Коли визначитеся з матеріалами й бюджетом, роботи «під ключ» у Смілі виконає бригада V.G.BuildingTeam — із договором і гарантією.</p>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <a href="https://vgb.team/" target="_blank" rel="noopener" class="btn lg">Перейти на vgb.team ↗</a>
        <a href="tel:+380977799513" class="btn ghost lg" style="text-align:center">📞 +38 (097) 779 95 13</a>
      </div>
    </div>
  </div></section>
</Base>
